# Local dev overrides — not committed to git
# Points at the Docker postgres exposed on port 5433
DATABASE_URL=postgresql+asyncpg://stlvault:changeme_strong_password_here@localhost:5433/stlvault
WEBUI_URL=http://localhost:5173
EXTRA_CORS_ORIGINS=http://localhost:5173
JWT_SECRET=changeme_generate_with_openssl_rand_hex_32
SMTP_HOST=
# Garage (local dev S3 — http://localhost:3900 after running docker-compose.dev.yml)
S3_ENDPOINT_URL=http://localhost:3900
S3_BUCKET_NAME=stlvault-dev
AWS_REGION=garage
AWS_ACCESS_KEY_ID=GKdevkey000000000000
AWS_SECRET_ACCESS_KEY=devsecretkey00000000000000000000
# Set to your .mil email to be promoted to admin on first startup
ADMIN_EMAIL=
